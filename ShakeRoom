local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local CameraShaker = require(game.ReplicatedStorage.CameraShaker)

local camera = workspace.CurrentCamera

-- Камера
local camShake = CameraShaker.new(Enum.RenderPriority.Camera.Value,function(cf)
	camera.CFrame *= cf
end)

camShake:Start()

-- Плавная тряска
camShake:ShakeOnce(
	1.5, -- сила
	20, -- скорость
	0.1, -- разгон
	1 -- затухание
)

-- Звук
local sound = Instance.new("Sound")
sound.Name = "Sound"
sound.SoundId = "rbxassetid://73416790112630"
sound.Volume = 2
sound.RollOffMaxDistance = 500
sound.Parent = workspace
sound:Play()

sound.Ended:Connect(function()
	sound:Destroy()
end)

local inserted = {}

for _, room in ipairs(workspace.CurrentRooms:GetChildren()) do
	for _, obj in ipairs(room:GetDescendants()) do
		if obj:IsA("BasePart") and obj.Name == "Ceiling" then

			local particle = game:GetObjects(
				"https://github.com/VanhelsinkOriginal/DoorsEntities/blob/main/Particle.rbxm?raw=true"
			)[1]

			particle.Parent = obj

			for _, v in ipairs(particle:GetDescendants()) do
				if v:IsA("ParticleEmitter") then
					v.Enabled = true
				end
			end

			table.insert(inserted, particle)
		end
	end
end

-- Через 3 секунды отключаем пыль
task.delay(3,function()

	for _, particle in ipairs(inserted) do
		if particle and particle.Parent then
			for _, v in ipairs(particle:GetDescendants()) do
				if v:IsA("ParticleEmitter") then
					v.Enabled = false
				end
			end
		end
	end

end)

-- Через 4 секунды удаляем
task.delay(4,function()

	for _, particle in ipairs(inserted) do
		if particle then
			particle:Destroy()
		end
	end

end)
