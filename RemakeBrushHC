---====== Debug entity ======---

entity:SetCallback("OnSpawned", function()
  
local TweenService = game:GetService("TweenService")

local color = Color3.fromRGB(0, 0, 255)

local tweenInfo = TweenInfo.new(
	0.5,
	Enum.EasingStyle.Sine,
	Enum.EasingDirection.Out
)

for _, room in ipairs(workspace.CurrentRooms:GetChildren()) do

	local assets = room:FindFirstChild("Assets")
	if not assets then
		continue
	end

	-- LightStand, LightStand1...LightStand9
	for i = 0, 9 do
		local standName = (i == 0) and "LightStand" or ("LightStand" .. i)
		local stand = assets:FindFirstChild(standName)

		if stand and stand:FindFirstChild("LightFixture") then
			local fixture = stand.LightFixture

			local objects = {
				fixture:FindFirstChild("PointLight"),
				fixture:FindFirstChild("Neon"),
				fixture.Neon and fixture.Neon.CenterAttach:FindFirstChild("PointLight1"),
				fixture.Neon and fixture.Neon.CenterAttach:FindFirstChild("SpotLight")
			}

			for _, obj in ipairs(objects) do
				if obj then
					TweenService:Create(obj, tweenInfo, {
						Color = color
					}):Play()
				end
			end
		end
	end

	-- Chandelier
	local chandelier = assets:FindFirstChild("Chandelier")

	if chandelier and chandelier:FindFirstChild("LightFixture") then
		local fixture = chandelier.LightFixture

		local objects = {
			fixture:FindFirstChild("PointLight"),
			fixture:FindFirstChild("SpotLight"),
			fixture:FindFirstChild("Neon")
		}

		for _, obj in ipairs(objects) do
			if obj then
				TweenService:Create(obj, tweenInfo, {
					Color = color
				}):Play()
			end
		end
	end

end
                   
	print("Entity has spawned")
local sound = Instance.new("Sound")
sound.Name = "BrushSpawn"
sound.SoundId = "rbxassetid://112858474438081"
sound.Volume = 1
sound.Parent = workspace

sound:Play()

sound.Ended:Wait()

sound:Destroy()
end)

entity:SetCallback("OnStartMoving", function()
