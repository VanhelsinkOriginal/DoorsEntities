---====== Run entity ======---

local sound = Instance.new("Sound")
sound.Name = "BrushSpawn"
sound.SoundId = "rbxassetid://112858474438081"
sound.Volume = 1
sound.Parent = workspace

sound:Play()

sound.Ended:Wait()

sound:Destroy()

task.wait(2)

entity:Run(true)
