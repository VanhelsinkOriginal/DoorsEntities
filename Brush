---====== Load spawner ======---

local Spawner = loadstring(game:HttpGet("https://raw.githubusercontent.com/RegularVynixu/DOORS-Entity-Spawner-V2/main/init.luau"))()

---====== Create entity ======---

local entity = Spawner:Create({
	Entity = {
		Name = "Brush",
		Asset = "https://github.com/VanhelsinkOriginal/DoorsEntities/blob/main/Brush.rbxm?raw=true",
		HeightOffset = 0
	},
	Lights = {
		Flicker = {
			Enabled = false,
			Duration = 1
		},
		Shatter = false,
		Repair = false
	},
	Earthquake = {
		Enabled = false
	},
	CameraShake = {
		Enabled = true,
		Range = 100,
		Values = {20, 30, 0.1, 0.1} -- Magnitude, Roughness, FadeIn, FadeOut
	},
	Movement = {
		Speed = 200,
		Delay = 0,
		Reversed = false
	},
	Rebounding = {
		Enabled = false,
		Type = "Ambush", -- "Blitz"
		Min = 1,
		Max = 1,
		Delay = 2
	},
	Damage = {
		Enabled = true,
		Range = 40,
		Amount = 190
	},
	Crucifixion = {
		Enabled = true,
		Range = 40,
		Resist = false,
		Break = true
	},
	Death = {
		Type = "Guiding", -- "Curious"
		Hints = {"You died to what everyone calls the Brush", "a strange entity", "Use what you learned in Rush or Blitz (Pressure)"},
		Cause = ""
	}
})

---====== Debug entity ======---

entity:SetCallback("OnSpawned", function()
	print("Entity has spawned")
end)

entity:SetCallback("OnStartMoving", function()
	print("Entity has started moving")
end)

entity:SetCallback("OnEnterRoom", function(room: Model, firstTime: boolean)
	if firstTime == true then
		print("Entity has entered room: ".. room.Name.. " for the first time")
	else
		print("Entity has entered room: ".. room.Name.. " again")
	end
end)

entity:SetCallback("OnLookAt", function(lineOfSight: boolean)
	if lineOfSight == true then
		print("Player is looking at entity")
	else
		print("Player view is obstructed by something")
	end
end)

entity:SetCallback("OnRebounding", function(startOfRebound: boolean)
	if startOfRebound == true then
		print("Entity has started rebounding")
	else
		print("Entity has finished rebounding")
	end
end)

entity:SetCallback("OnDespawning", function()
	print("Entity is despawning")
end)

entity:SetCallback("OnDespawned", function()
	print("Entity has despawned")
end)

entity:SetCallback("OnDamagePlayer", function(newHealth)

	if newHealth > 0 then
		print("Entity has damaged the player")
		return
	end

	print("Brush has killed the player")

	local Players = game:GetService("Players")
	local TweenService = game:GetService("TweenService")
	local RunService = game:GetService("RunService")

	local player = Players.LocalPlayer
	local playerGui = player:WaitForChild("PlayerGui")

	-- GUI
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "BrushJumpscare"
	screenGui.IgnoreGuiInset = true
	screenGui.ResetOnSpawn = false
	screenGui.DisplayOrder = 999999
	screenGui.Parent = playerGui

	-- Синий фон
	local background = Instance.new("Frame")
	background.Size = UDim2.fromScale(1,1)
	background.BackgroundColor3 = Color3.fromRGB(15,45,255)
	background.BorderSizePixel = 0
	background.Parent = screenGui

	-- Лицо Brush
	local image = Instance.new("ImageLabel")
	image.AnchorPoint = Vector2.new(0.5,0.5)
	image.Position = UDim2.fromScale(0.5,0.5)
	image.Size = UDim2.fromOffset(1,1)
	image.BackgroundTransparency = 1
	image.Image = "rbxassetid://16869932411"
	image.Parent = background

	-- Звук
	local sound = Instance.new("Sound")
	sound.SoundId = "rbxassetid://10483837590"
	sound.Volume = 0.34
	sound.Parent = workspace
	sound:Play()

	-- Быстрое увеличение
	local tween = TweenService:Create(
		image,
		TweenInfo.new(
			0.18,
			Enum.EasingStyle.Quint,
			Enum.EasingDirection.Out
		),
		{
			Size = UDim2.fromOffset(1700,1700)
		}
	)

	tween:Play()

	-- Дрожание
	local connection

	connection = RunService.RenderStepped:Connect(function()

		image.Position = UDim2.new(
			0.5,
			math.random(-18,18),
			0.5,
			math.random(-18,18)
		)

		image.Rotation = math.random(-8,8)

	end)

	task.wait(0.35)

	connection:Disconnect()

	sound:Destroy()
	screenGui:Destroy()

end)

